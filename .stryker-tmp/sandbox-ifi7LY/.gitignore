# Dependencies
node_modules/
.pnpm-store/
.pnp.*

# Build artifacts
dist/
build/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env / secrets — 严禁提交（特别是微信支付 V3 商户号 + API 密钥 EXT-01）
.env
.env.*
!.env.example
*.pem
*.key
apiclient_*.pem

# Demo seed output — 含明文 admin 密码，永不 commit（F5 修复 2026-05-19）
# 通配整个 seed 子目录的 json（generator JS 输出 + 含 PII），但放行 fixtures
scripts/seed/demo-users.json
scripts/seed/*.json
!scripts/seed/fixtures.json
# baseline reports (smoke + verify) 含运行时数据，不入库（这些在 /tmp 不在 repo，保险起见）
/tmp/seed-*.sql
/tmp/seed-*.log
/tmp/spec-*.json
/tmp/provision-resp.*.json
/tmp/provision-body.*.json
/tmp/snapshot-*.sql

# Editor
.vscode/
.idea/
*.swp
.DS_Store

# Test coverage
coverage/
.nyc_output/

# Local DB / runtime
docker-volumes/
postgres-data/
redis-data/

# OS
Thumbs.db
