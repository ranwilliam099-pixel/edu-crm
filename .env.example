# ============================================================
# edu-server 环境变量样例（W0-D1 起草）
# 复制为 .env，填写真实值；.env 已被 .gitignore，禁止提交
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3001
APP_NAME=edu-server

# --- PostgreSQL（W0 用本地 docker；线上等 INT-01 落实）---
DB_HOST=127.0.0.1
DB_PORT=6432
DB_USER=eduapp
DB_PASSWORD=eduapp
DB_NAME=edudb
DB_PUBLIC_SCHEMA=public
# T13 (2026-05-16): PgBouncer + 连接池调参
# - DB_PORT=6432：经 PgBouncer 本机代理（原 5432 直连 PG，6432 走 pgbouncer session mode）
# - DB_POOL_MAX=25：应用 pg.Pool max（原 10 → 25，匹配 PgBouncer default_pool_size）
# - DB_STATEMENT_TIMEOUT_MS=5000：应用查询超时（与 PgBouncer query_wait_timeout 对齐 fail-fast）
#
# ⚠️ T13 round 2 (W1 production audit finding): pg_dump 备份必须直连 PG 5432，不走 PgBouncer
#   理由：PgBouncer session mode 与 pg_dump 的 COPY 协议 / 多语句流不兼容
#   实施：scripts/backup/pg-backup-daily.sh 用独立 PG_HOST/PG_PORT 变量（不读 DB_HOST/DB_PORT）
#   crontab 部署：保持 PG_PORT=5432 默认值，不要跟随 DB_PORT=6432
#   见 spec §5 部署 SOP T13-FU-W1 condition
DB_POOL_MAX=25
DB_STATEMENT_TIMEOUT_MS=5000

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- JWT ---
JWT_SECRET=__CHANGE_ME_IN_PROD__
JWT_TTL_SEC=86400
# T11 (2026-05-16): refresh token rotation TTL（OAuth 2.0 RFC 6749/6819 业界标准）
# - B 端员工 7d；C 端家长 30d
JWT_REFRESH_TTL_B_SEC=604800
JWT_REFRESH_TTL_PARENT_SEC=2592000

# --- CORS（Sprint E.1 2026-05-13）---
# 逗号分隔的浏览器 origin 白名单。微信小程序、curl、内部 cron 无 origin，无需配置。
# dev:  http://localhost:3000,http://localhost:5173
# prod: https://minxin.top,https://app.minxin.top
CORS_ALLOWED_ORIGINS=

# --- 微信支付 V3（EXT-01 商户号到位前留空；不允许猜测填假值）---
WXPAY_MCHID=
WXPAY_API_V3_KEY=
WXPAY_SERIAL_NO=
WXPAY_PRIVATE_KEY_PATH=
WXPAY_NOTIFY_URL=https://api.placeholder.local/api/checkout/callbacks/wxpay

# --- T14 微信支付容灾：主备商户号 ENV 双值方案（2026-05-16 拍板）---
# 切换 SOP：sed -i 's/_ACTIVE=primary/_ACTIVE=fallback/' .env && pm2 reload --update-env
# 向后兼容：若 _PRIMARY 缺，自动回退到上面旧无后缀 ENV（WXPAY_MCHID 等）
# WXPAY_API_V3_KEY + WXPAY_APP_ID + WXPAY_NOTIFY_URL 不分主备（商户号外部共享）
WXPAY_MCHID_ACTIVE=primary
WXPAY_MCHID_PRIMARY=
WXPAY_MCHID_FALLBACK=
WXPAY_SERIAL_NO_PRIMARY=
WXPAY_SERIAL_NO_FALLBACK=
WXPAY_PRIVATE_KEY_PATH_PRIMARY=
WXPAY_PRIVATE_KEY_PATH_FALLBACK=
WXPAY_CERT_PATH_PRIMARY=
WXPAY_CERT_PATH_FALLBACK=
WXPAY_PUB_KEY_PATH_PRIMARY=
WXPAY_PUB_KEY_PATH_FALLBACK=
WXPAY_PUB_KEY_ID_PRIMARY=
WXPAY_PUB_KEY_ID_FALLBACK=

# --- 小程序 appId（EXT-02 待项目经理确认）---
WX_APPID=
WX_APPSECRET=

# --- A09 帮助文档站（EXT-03 占位）---
HELP_DOC_BASE_URL=https://help.placeholder.local

# --- V34 / V40 字段级加密（个保法红线）---
# ENCRYPTION_KEY: AES-256-GCM 加密所有敏感字段（teacher.phone / customer.phone / parent.phone_encrypted）
# HASH_KEY:       HMAC-SHA256 确定性哈希（parent.phone_hash 等值查询用，C 端登录）
# 两个 key 必须**独立**生成（密钥分离原则）：
#   openssl rand -base64 32   # 各跑一次
# 缺失任一 key → 服务启动失败（fail-close）
ENCRYPTION_KEY=
HASH_KEY=

# ============================================================
# L7 Observability（2026-05-19 Day 4 接入，v2.0 §3.L7）
# ============================================================
#
# --- Sentry（P0 第 6 项，DSN 缺失 fail-open 不影响运行）---
# 申请：https://sentry.io（Free 5K err/月）
# 行为：
#   - SENTRY_DSN 缺失 / 为空 → 不 init（dev/test 不强依赖）
#   - production env → 采样 10%（控成本）；development → 100%
#   - PII redact 沿用 pino 35 字段策略（cookie / authorization / phone / id_number / token...）
SENTRY_DSN=
SENTRY_RELEASE=

# --- 告警 webhook（P0 第 8 项，双轨 fail-open）---
# 钉钉群机器人 webhook：群设置 → 智能群助手 → 添加机器人 → 自定义
# 企微（WeWork）群机器人 webhook：群设置 → 群机器人 → 添加 → 复制 Webhook
# 两个都留空 → 仅 logger.warn（不抛错），任配 1 个即生效，2 个都配则双轨并发发送
# AlertService dedup 默认 30s 窗口（防 spam）
DINGTALK_WEBHOOK=
WEWORK_WEBHOOK=

# --- 业务关键路径成功率监控阈值（BusinessMetricsInterceptor）---
# 拦截 3 个关键路径：POST /db/customers / POST /checkout/wxpay/unified-order / POST /public/auth/login
# 错误率 > BUSINESS_METRICS_ERROR_THRESHOLD 持续 BUSINESS_METRICS_WINDOW_MIN 分钟 → 钉钉告警
# 默认 1% / 5min（v2.0 §3.L7 拍板）
BUSINESS_METRICS_ERROR_THRESHOLD=0.01
BUSINESS_METRICS_WINDOW_MIN=5
# 单端点 5xx > 此阈值 / min → 立即告警（无需窗口聚合）
BUSINESS_METRICS_5XX_RATE_PER_MIN=10
