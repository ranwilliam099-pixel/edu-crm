# ============================================================
# edu-server 环境变量样例（W0-D1 起草）
# 复制为 .env，填写真实值；.env 已被 .gitignore，禁止提交
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3001
APP_NAME=edu-server

# --- PostgreSQL（W0 用本地 docker；线上等 INT-01 落实）---
DB_HOST=localhost
DB_PORT=5432
DB_USER=eduapp
DB_PASSWORD=eduapp
DB_NAME=edudb
DB_PUBLIC_SCHEMA=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- JWT ---
JWT_SECRET=__CHANGE_ME_IN_PROD__
JWT_TTL_SEC=86400

# --- 微信支付 V3（EXT-01 商户号到位前留空；不允许猜测填假值）---
WXPAY_MCHID=
WXPAY_API_V3_KEY=
WXPAY_SERIAL_NO=
WXPAY_PRIVATE_KEY_PATH=
WXPAY_NOTIFY_URL=https://api.placeholder.local/api/checkout/callbacks/wxpay

# --- 小程序 appId（EXT-02 待项目经理确认）---
WX_APPID=
WX_APPSECRET=

# --- A09 帮助文档站（EXT-03 占位）---
HELP_DOC_BASE_URL=https://help.placeholder.local

# --- V34 / V40 字段级加密（个保法红线）---
# ENCRYPTION_KEY: AES-256-GCM 加密所有敏感字段（teacher.phone / customer.phone / parent.phone_encrypted）
# HASH_KEY:       HMAC-SHA256 确定性哈希（parent.phone_hash 等值查询用，C 端登录）
# 两个 key 必须**独立**生成（密钥分离原则）：
#   openssl rand -base64 32   # 各跑一次
# 缺失任一 key → 服务启动失败（fail-close）
ENCRYPTION_KEY=
HASH_KEY=
